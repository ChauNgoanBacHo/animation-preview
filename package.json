{
  "name": "animation-preview-app",
  "productName": "Animation Preview",
  "version": "1.0.0",
  "description": "Desktop app for previewing Spine animation folders",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:win": "electron-forge make --platform=win32",
    "make:zip": "electron-forge make --platform=darwin --targets=@electron-forge/maker-zip",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\""
  },
  "keywords": [],
  "author": {
    "name": "TiTi",
    "email": "tien.huynh@enotion.io"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "electron": "^42.3.3",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "pixi-spine": "^4.0.6",
    "pixi.js": "^7.4.3"
  }
}
